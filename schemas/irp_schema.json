{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Implementation Report (IRP)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^IRP-v[0-9]+$" },
    "outcome": { "enum": ["ready", "needs info", "blocked"] },
    "recipient": { "enum": ["QA", "Manager"] },
    "parent_request": { "const": "IRQ.md" },
    "implementing_actor": { "const": "Doer" },
    "implementation_round": { "type": "integer" },
    "last_qa_report": { "type": "string" }
  },
  "required": ["id", "outcome", "recipient", "parent_request", "implementing_actor", "implementation_round"]
}
